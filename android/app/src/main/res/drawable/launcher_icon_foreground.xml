<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/apk/res-auto"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="512"
    android:viewportHeight="512">

    <!-- Scaling Group to center and fit within the adaptive safe zone (72% scale) -->
    <group
        android:scaleX="0.72"
        android:scaleY="0.72"
        android:translateX="71.68"
        android:translateY="71.68">

        <!-- Outer play/R ribbon curve (stroke width 44) -->
        <path
            android:pathData="M 160,120 L 160,392 C 160,405 175,412 185,404 L 380,268 C 390,260 390,252 380,244 L 240,140 C 230,132 215,138 215,152 L 215,270"
            android:strokeWidth="44"
            android:strokeLineCap="round"
            android:strokeLineJoin="round">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:startX="160"
                    android:startY="120"
                    android:endX="380"
                    android:endY="404"
                    android:type="linear">
                    <item android:offset="0" android:color="#FF2D55" /> <!-- Cheerful Pink -->
                    <item android:offset="0.5" android:color="#FF5E3A" /> <!-- Orange -->
                    <item android:offset="1" android:color="#FFB300" /> <!-- Sunset Gold -->
                </gradient>
            </aapt:attr>
        </path>

        <!-- Innermost playful play core indicator -->
        <path
            android:pathData="M 235,210 L 295,256 L 235,302 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="235"
                    android:startY="210"
                    android:endX="295"
                    android:endY="302"
                    android:type="linear">
                    <item android:offset="0" android:color="#FF2D55" />
                    <item android:offset="1" android:color="#AF52DE" /> <!-- Purple -->
                </gradient>
            </aapt:attr>
        </path>
    </group>
</vector>
